# ===== アプリ設定 =====
DATABASE_URL=sqlite:///./globalbiz.db
LOG_LEVEL=INFO

# ===== 価格設定 =====
DEFAULT_MARKUP_RATE=1.3        # 仕入れ値 × 1.3 = 販売価格
DEFAULT_EXCHANGE_RATE_USD=150  # 円→ドル換算
DEFAULT_EXCHANGE_RATE_SGD=112  # 円→SGD換算（Shopee）
SHIPPING_COST_DOMESTIC=800     # 国内送料（円）
