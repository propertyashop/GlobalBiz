# ===== eBay Trading API =====
# eBay Developer Portal: https://developer.ebay.com/my/keys
EBAY_APP_ID=YourApp-Name-PRD-xxxxxxxxx-xxxxxxxx
EBAY_DEV_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
EBAY_CERT_ID=PRD-xxxxxxxxxxxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# User Token: eBay Developer Portal → Get a User Token
EBAY_USER_TOKEN=v^1.1#i^1#...（トークン全体をペースト）
EBAY_SITE_ID=0
EBAY_SANDBOX=false

# ===== Shopee Open Platform API =====
# Shopee Partner Portal: https://open.shopee.com
SHOPEE_PARTNER_ID=123456
SHOPEE_PARTNER_KEY=your_partner_key_here
SHOPEE_SHOP_ID=123456789
SHOPEE_ACCESS_TOKEN=your_access_token_here
SHOPEE_SANDBOX=false

# ===== 仕入れ元 API =====
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=
AMAZON_REFRESH_TOKEN=
AMAZON_MARKETPLACE_ID=A1VC38T7YXB528
RAKUTEN_APP_ID=
YAHOO_CLIENT_ID=
NETSEA_EMAIL=
NETSEA_PASSWORD=

# ===== 価格・為替レート =====
DEFAULT_EXCHANGE_RATE_USD=150
DEFAULT_EXCHANGE_RATE_SGD=112
EBAY_FEE_RATE=0.13
SHOPEE_FEE_RATE=0.06
PAYMENT_FEE_RATE=0.044
FX_FEE_RATE=0.02

# ===== アプリ設定 =====
DATABASE_URL=sqlite:///./globalbiz.db
LOG_LEVEL=INFO
